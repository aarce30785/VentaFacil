@model IEnumerable<VentaFacil.web.Models.InventarioMovimientoAuditoria>

<div class="modal fade" id="auditoriaModal" tabindex="-1" aria-labelledby="auditoriaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="auditoriaModalLabel">
                    <i class="lni lni-timer text-primary me-2"></i> Historial de Correcciones
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body py-4">
                <div class="mb-3">
                    <span class="badge bg-primary rounded-pill px-3 py-2">
                        Movimiento ID: #@ViewBag.IdMovimiento
                    </span>
                </div>

                <div class="table-container animate-fade-in border rounded-3 p-3 bg-light">
                    <div class="table-responsive">
                        <table class="table premium-table mb-0">
                            <thead>
                                <tr>
                                    <th><h6>Fecha y Hora</h6></th>
                                    <th><h6>Usuario</h6></th>
                                    <th><h6>Motivo del Cambio</h6></th>
                                    <th><h6>Cambio de Stock</h6></th>
                                    <th><h6>Tipo de Movimiento</h6></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    foreach (var auditoria in Model)
                                    {
                                        <tr>
                                            <td class="min-width align-middle">
                                                <span class="text-sm fw-bold">@auditoria.FechaCambio.ToString("dd/MM/yyyy HH:mm")</span>
                                            </td>
                                            <td class="min-width align-middle">
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar-sm bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center me-2" style="width: 24px; height: 24px;">
                                                        <span class="text-primary fw-bold" style="font-size: 0.7rem;">
                                                            @(string.IsNullOrEmpty(auditoria.UsuarioResponsable?.Nombre) ? "U" : auditoria.UsuarioResponsable.Nombre.Substring(0, 1).ToUpper())
                                                        </span>
                                                    </div>
                                                    <span class="text-sm">@(auditoria.UsuarioResponsable?.Nombre ?? "Sistema")</span>
                                                </div>
                                            </td>
                                            <td class="min-width align-middle">
                                                <p class="text-sm mb-0 text-wrap" style="max-width: 200px;">@auditoria.MotivoCambio</p>
                                            </td>
                                            <td class="min-width align-middle">
                                                <div class="d-flex align-items-center justify-content-center bg-white border rounded p-1">
                                                    <span class="text-danger fw-bold me-2">@auditoria.CantidadAnterior</span>
                                                    <i class="lni lni-arrow-right text-muted mx-1"></i>
                                                    <span class="text-success fw-bold ms-2">@auditoria.CantidadNueva</span>
                                                </div>
                                            </td>
                                            <td class="min-width align-middle">
                                                <div class="d-flex flex-column gap-1">
                                                    <span class="badge bg-secondary opacity-75">Antes: @auditoria.TipoMovimientoAnterior</span>
                                                    <span class="badge bg-primary">Después: @auditoria.TipoMovimientoNuevo</span>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="empty-state">
                                                <div class="mb-3">
                                                    <div class="avatar-lg bg-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-sm" style="width: 64px; height: 64px;">
                                                        <i class="lni lni-timer fs-2 text-muted"></i>
                                                    </div>
                                                </div>
                                                <h6 class="fw-bold text-muted">Sin correcciones</h6>
                                                <p class="text-muted text-sm mb-0">Este movimiento no ha sido modificado.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>
