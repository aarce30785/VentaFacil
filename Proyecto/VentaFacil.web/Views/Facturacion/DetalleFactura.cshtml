@using VentaFacil.web.Models.ViewModel
@using System.Globalization
@model DetalleFacturaViewModel
@{
    ViewData["Title"] = "Detalle de Factura";
    Layout = "_LayoutPlantilla";
    var cultureCR = CultureInfo.GetCultureInfo("es-CR");
    // Ensure the symbol is correct regardless of server settings
    var numberFormat = (NumberFormatInfo)cultureCR.NumberFormat.Clone();
    numberFormat.CurrencySymbol = "¢";
}

<style>
    :root {
        --primary-color: #4f46e5;
        --primary-hover: #4338ca;
        --success-color: #10b981;
        --bg-color: #f8fafc;
        --card-bg: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --card-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
    }
    .premium-card {
        background: var(--card-bg);
        border-radius: 24px;
        box-shadow: var(--card-shadow);
        overflow: hidden;
        border: 1px solid #e5e7eb;
        margin-bottom: 2rem;
        padding: 2.5rem 2rem 2rem 2rem;
    }
    .premium-header {
        background: #ffffff;
        padding: 2.5rem 2rem 2rem 2rem;
        color: var(--text-main);
        text-align: center;
        border-radius: 24px 24px 0 0;
        margin-bottom: 0;
        border-bottom: 1px solid #f1f5f9;
        margin-top: -2.5rem; /* Ajuste para compensar padding del card */
        margin-left: -2rem;
        margin-right: -2rem;
    }
    .success-badge {
        width: 80px;
        height: 80px;
        background: var(--success-color);
        backdrop-filter: blur(8px);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }
    .info-group {
        background: #f8fafc;
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 2rem;
        border: 1px solid #e2e8f0;
    }
    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        font-weight: 700; /* Increased weight for visibility */
        margin-bottom: 0.25rem;
    }
    .info-value {
        font-size: 1.1rem; /* Slightly larger */
        font-weight: 700;
        color: var(--text-main);
    }
    .premium-table {
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
        background: #fff;
    }
    .premium-table thead th {
        background-color: #f1f5f9; /* Darker header for contrast */
        color: #0f172a; /* Darker text */
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        border-bottom: 2px solid #cbd5e1;
        padding: 1rem;
    }
    .premium-table tbody td {
        padding: 1rem 0.5rem;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
        font-weight: 500;
    }
    .premium-table tbody tr:last-child td {
        border-bottom: none;
    }
    .premium-table tbody tr:hover {
        background-color: #f8fafc;
    }
    .total-section {
        background: #1e293b;
        color: white;
        border-radius: 16px;
        padding: 2rem;
        margin-top: 2rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .total-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.75rem;
        opacity: 1; /* Removed opacity for better contrast */
        font-size: 1.05rem;
    }
    .total-row span:first-child {
        color: #cbd5e1; /* Lighter text for labels */
    }
    .total-row span:last-child {
        font-weight: 600;
        color: #ffffff; /* Pure white for values */
    }
    .total-row.final {
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255,255,255,0.3); /* Higher contrast border */
        font-size: 1.5rem;
        font-weight: 800;
    }
    .total-row.final span:first-child {
        color: #ffffff;
    }
    .btn-premium {
        border-radius: 30px !important;
        font-weight: 600;
        padding: 0.7rem 2rem;
        font-size: 1rem;
        margin-right: 0.5rem;
    }
    .btn-premium:last-child { margin-right: 0; }
    .badge-premium {
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.4em 1em;
        background: #fff;
        color: #4f46e5;
        border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(79,70,229,0.04);
    }
</style>

<div class="invoice-container">
    <div class="premium-card p-0">
        <div class="premium-header">
            <div class="success-badge">
                <i class="lni lni-checkmark fs-1 text-white"></i>
            </div>
            <h1 class="h3 fw-bold mb-2">¡Pago Exitoso!</h1>
            <p class="mb-0 opacity-75">Gracias por su compra</p>
        </div>
        <div class="invoice-body p-4" style="margin-top: 2rem;">
            <div class="info-group mb-4">
                <div class="row g-4">
                    <div class="col-6 col-md-3">
                        <div class="info-label">N° Factura</div>
                        <div class="info-value">#@(Model.Factura?.NumeroFactura ?? "---")</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-label">Fecha</div>
                        <div class="info-value">@(Model.Factura?.FechaEmision.ToString("dd/MM/yy HH:mm") ?? DateTime.Now.ToString("g"))</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-label">Cliente</div>
                        <div class="info-value">@(Model.Factura?.Cliente ?? "General")</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="info-label">Método</div>
                        <div class="info-value">
                            <span class="badge-premium">
                                @(Model.Factura?.MetodoPago.ToString() ?? "Efectivo")
                            </span>
                        </div>
                    </div>
                </div>
                <div class="total-section mt-4">
                    <div class="total-row">
                        <span>Subtotal</span>
                        <span>@((Model.Factura?.Subtotal ?? 0).ToString("C", numberFormat))</span>
                    </div>
                    <div class="total-row">
                        <span>Impuestos</span>
                        <span>@((Model.Factura?.Impuestos ?? 0).ToString("C", numberFormat))</span>
                    </div>
                    <div class="total-row final">
                        <span>Total</span>
                        <span>@((Model.Factura?.Total ?? 0).ToString("C", numberFormat))</span>
                    </div>
                    <div class="mt-4 pt-3 border-top border-secondary">
                        <div class="d-flex justify-content-between small mb-2" style="color: #cbd5e1;">
                            <span>Pagado con @(Model.Factura?.Moneda ?? "CRC")</span>
                            <span class="fw-bold text-white">
                                @if (Model.Factura?.Moneda == "USD")
                                {
                                    <text>$@((Model.Factura?.MontoPagado ?? 0).ToString("N2"))</text>
                                }
                                else
                                {
                                    <text>@((Model.Factura?.MontoPagado ?? 0).ToString("C", numberFormat))</text>
                                }
                            </span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold">
                            <span class="text-white">Cambio Entregado (¢)</span>
                            <span class="text-success fs-5">@((Model.Factura?.Cambio ?? 0).ToString("C", numberFormat))</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="info-group">
                <h5 class="mb-3 fw-bold">Detalle de Productos</h5>
                <form id="formDevolucion" method="post" action="@Url.Action("Devolucion", "Facturacion")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="facturaId" value="@Model.FacturaId" />
                    <div class="table-responsive">
                        <table class="table premium-table">
                            <thead>
                                <tr>
                                    @if (Model.Factura?.EstadoFactura == VentaFacil.web.Models.Enum.EstadoFactura.Activa)
                                    {
                                        <th style="width: 50px;">Dev.</th>
                                    }
                                    <th>Producto</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">Precio</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Items != null)
                                {
                                    foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            @if (Model.Factura?.EstadoFactura == VentaFacil.web.Models.Enum.EstadoFactura.Activa)
                                            {
                                                <td>
                                                    <div class="form-check">
                                                        <input class="form-check-input item-devolucion" type="checkbox" name="itemsDevolver" value="@item.ProductoId">
                                                    </div>
                                                </td>
                                            }
                                            <td>@item.NombreProducto</td>
                                            <td class="text-center">@item.Cantidad</td>
                                            <td class="text-end">@item.PrecioUnitario.ToString("C", numberFormat)</td>
                                            <td class="text-end">@item.Subtotal.ToString("C", numberFormat)</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.Factura?.EstadoFactura == VentaFacil.web.Models.Enum.EstadoFactura.Activa)
                    {
                        <div class="mt-3 text-end">
                            <button type="submit" class="btn btn-warning btn-premium btn-sm" id="btnProcesarDevolucion" disabled>
                                <i class="lni lni-undo"></i> Procesar Devolución Seleccionada
                            </button>
                        </div>
                    }
                </form>
            </div>
            <div class="d-grid gap-3 d-md-flex justify-content-md-between align-items-center mt-5">
                <a href="@Url.Action("Index", "Pedidos")" class="btn btn-light btn-premium">
                    <i class="lni lni-arrow-left"></i> Volver a Pedidos
                </a>
                <div class="d-flex gap-2 flex-wrap justify-content-end">
                    <button type="button" class="btn btn-success btn-premium" data-bs-toggle="modal" data-bs-target="#modalEnviarEmail">
                        <i class="lni lni-envelope me-2"></i> Enviar por Email
                    </button>
                    <button id="btnDescargarPdf" class="btn btn-primary btn-premium px-5">
                        <i class="lni lni-download"></i> Descargar PDF
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Enviar por Email -->
<div class="modal fade" id="modalEnviarEmail" tabindex="-1" aria-labelledby="modalEnviarEmailLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
            <div class="modal-header" style="background: linear-gradient(135deg, #4f46e5, #6366f1); border-radius: 16px 16px 0 0; border: none;">
                <h5 class="modal-title text-white fw-bold" id="modalEnviarEmailLabel">
                    <i class="lni lni-envelope me-2"></i>Enviar Factura por Correo
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted mb-3">Ingrese el correo electrónico del destinatario. Se enviará la factura <strong>@(Model.Factura?.NumeroFactura)</strong> en formato PDF.</p>
                <div class="mb-3">
                    <label for="inputEmailDestino" class="form-label fw-bold">Correo electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="lni lni-envelope"></i></span>
                        <input type="email" id="inputEmailDestino" class="form-control form-control-lg"
                               placeholder="cliente@ejemplo.com" autocomplete="email" />
                    </div>
                    <div id="emailErrorMsg" class="text-danger small mt-1" style="display:none;"></div>
                </div>
                <!-- Toast de resultado -->
                <div id="emailToast" class="alert d-none mb-0" role="alert"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btnEnviarEmail" class="btn btn-primary rounded-pill px-4 fw-bold">
                    <i class="lni lni-envelope me-2"></i> Enviar Factura
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const btnDescargarPdf = document.getElementById('btnDescargarPdf');

            // ── ENVÍO POR EMAIL ──────────────────────────────────────────
            const btnEnviarEmail = document.getElementById('btnEnviarEmail');
            const inputEmail = document.getElementById('inputEmailDestino');
            const emailToast = document.getElementById('emailToast');
            const emailErrorMsg = document.getElementById('emailErrorMsg');
            const facturaId = @Model.FacturaId;

            if (btnEnviarEmail) {
                inputEmail.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') {
                        btnEnviarEmail.click();
                    }
                });
                
                btnEnviarEmail.addEventListener('click', async function () {
                    const email = inputEmail.value.trim();
                    const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

                    emailErrorMsg.style.display = 'none';
                    emailToast.classList.add('d-none');

                    if (!email || !emailRegex.test(email)) {
                        emailErrorMsg.textContent = 'Por favor ingrese un correo electrónico válido.';
                        emailErrorMsg.style.display = 'block';
                        inputEmail.focus();
                        return;
                    }

                    const originalHtml = btnEnviarEmail.innerHTML;
                    btnEnviarEmail.disabled = true;
                    btnEnviarEmail.innerHTML = '<i class="lni lni-spinner lni-spin me-2"></i> Enviando...';

                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                                     ?? document.cookie.match(/XSRF-TOKEN=([^;]+)/)?.[1] ?? '';

                        const formData = new FormData();
                        formData.append('facturaId', facturaId);
                        formData.append('emailDestino', email);
                        formData.append('__RequestVerificationToken', token);

                        const res = await fetch('/Facturacion/EnviarPorEmail', {
                            method: 'POST',
                            headers: { 
                                'X-CSRF-TOKEN': token 
                            },
                            body: formData
                        });

                        if (!res.ok) {
                            const errorText = await res.text();
                            throw new Error(errorText || `Error ${res.status}: ${res.statusText}`);
                        }

                        const data = await res.json();

                        if (data.success) {
                            emailToast.className = 'alert alert-success';
                            emailToast.innerHTML = '<i class="lni lni-checkmark-circle me-2"></i>' + data.message;
                            inputEmail.value = '';
                        } else {
                            emailToast.className = 'alert alert-danger';
                            emailToast.innerHTML = '<i class="lni lni-warning me-2"></i>' + data.message;
                        }

                    } catch (err) {
                        emailToast.className = 'alert alert-danger';
                        emailToast.innerHTML = '<i class="lni lni-warning me-2"></i>' + (err.message || 'Error de conexión al enviar el correo.');
                        console.error('Error al enviar email:', err);
                    } finally {
                        btnEnviarEmail.disabled = false;
                        btnEnviarEmail.innerHTML = originalHtml;
                    }
                });
            }

            // Resetear modal al cerrarlo
            document.getElementById('modalEnviarEmail')?.addEventListener('hidden.bs.modal', function () {
                inputEmail.value = '';
                emailErrorMsg.style.display = 'none';
                emailToast.className = 'alert d-none';
                emailToast.innerHTML = '';
            });
            // ── FIN ENVÍO POR EMAIL ──────────────────────────────────────

            // Lógica para habilitar botón de devolución
            const checkboxes = document.querySelectorAll('.item-devolucion');

            const btnDevolucion = document.getElementById('btnProcesarDevolucion');

            if (checkboxes.length > 0 && btnDevolucion) {
                checkboxes.forEach(cb => {
                    cb.addEventListener('change', function() {
                        const anyChecked = Array.from(checkboxes).some(c => c.checked);
                        btnDevolucion.disabled = !anyChecked;
                    });
                });
            }

            // Usar el ID definido arriba
            const pdfUrl = `/Facturacion/DescargarFactura?facturaId=${facturaId}`;

            if (btnDescargarPdf) {
                btnDescargarPdf.addEventListener('click', function() {
                    descargarDirecto();
                });
            }

            async function descargarDirecto() {
                if (!facturaId || facturaId === 0) {
                    alert('Error: No se pudo obtener el ID de la factura.');
                    return;
                }

                const originalText = btnDescargarPdf.innerHTML;
                btnDescargarPdf.disabled = true;
                btnDescargarPdf.innerHTML = '<i class="lni lni-spinner lni-spin me-2"></i> Descargando...';

                try {
                    const response = await fetch(pdfUrl);

                    
                    if (!response.ok) {
                        const errorText = await response.text();
                        throw new Error(`Error ${response.status}: ${response.statusText}`);
                    }

                    
                    const contentType = response.headers.get('content-type');
                    if (!contentType || !contentType.includes('application/pdf')) {
                        throw new Error('La respuesta no es un PDF válido');
                    }

                    const blob = await response.blob();

                   
                    if (blob.size === 0) {
                        throw new Error('El archivo PDF está vacío');
                    }

                    const url = window.URL.createObjectURL(blob);
                    const link = document.createElement('a');
                    link.href = url;
                    link.download = `Factura-${facturaId}.pdf`;
                    link.style.display = 'none';
                    document.body.appendChild(link);

                    
                    link.addEventListener('click', function() {
                        setTimeout(() => {
                            window.URL.revokeObjectURL(url);
                            document.body.removeChild(link);
                            btnDescargarPdf.disabled = false;
                            btnDescargarPdf.innerHTML = originalText;
                        }, 100);
                    });

                    link.click();

                } catch (error) {
                    console.error('Error en la descarga:', error);

                   
                    if (error.message.includes('Error 404')) {
                        alert('No se encontró la factura solicitada.');
                    } else if (error.message.includes('Error 500')) {
                        alert('Error del servidor al generar la factura.');
                    } else if (error.message.includes('PDF')) {
                        alert('Error: No se pudo generar el PDF correctamente.');
                    } else {
                        alert('Hubo un error al descargar la factura: ' + error.message);
                    }
                } finally {
                    
                    setTimeout(() => {
                        if (!btnDescargarPdf.disabled) return;
                        btnDescargarPdf.disabled = false;
                        btnDescargarPdf.innerHTML = originalText;
                    }, 3000);
                }
            }
        });

        async function imprimirFactura(esCopia) {
            const facturaId = @Model.FacturaId;
            const url = `/Facturacion/DescargarFactura?facturaId=${facturaId}&esCopia=${esCopia}`;

            try {
                // Show a small toast/alert indicating processing
                var btnImprimir = document.querySelector('button[onclick="imprimirFactura(false)"], button[onclick="imprimirFactura(true)"]');
                var originalText = btnImprimir ? btnImprimir.innerHTML : "";
                if(btnImprimir) {
                    btnImprimir.disabled = true;
                    btnImprimir.innerHTML = '<i class="lni lni-spinner lni-spin me-2"></i> Generando...';
                }

                const response = await fetch(url);
                if (!response.ok) throw new Error('Error al generar la factura. Verifique conexión a la impresora o sistema.');

                const blob = await response.blob();
                const blobUrl = URL.createObjectURL(blob);

                // Crear un iframe oculto para imprimir
                const iframe = document.createElement('iframe');
                iframe.style.display = 'none';
                iframe.src = blobUrl;
                document.body.appendChild(iframe);

                iframe.onload = function () {
                    setTimeout(function () {
                        try {
                            iframe.contentWindow.focus();
                            
                            // Try to hook onafterprint
                            iframe.contentWindow.onafterprint = function() {
                                if (document.body.contains(iframe)) {
                                    document.body.removeChild(iframe);
                                    URL.revokeObjectURL(blobUrl);
                                }
                            };
                            
                            iframe.contentWindow.print();
                            
                            // Fallback timeout in case onafterprint not supported/fired
                            setTimeout(() => {
                                if (document.body.contains(iframe)) {
                                    document.body.removeChild(iframe);
                                    URL.revokeObjectURL(blobUrl);
                                }
                            }, 120000); 

                            if(btnImprimir) {
                                btnImprimir.disabled = false;
                                btnImprimir.innerHTML = originalText;
                            }
                            
                        } catch (e) {
                            console.error('Error al imprimir:', e);
                            alert('Hubo un problema de comunicación al abrir el diálogo de impresión.');
                            if(btnImprimir) {
                                btnImprimir.disabled = false;
                                btnImprimir.innerHTML = originalText;
                            }
                        }
                    }, 500);
                };

            } catch (error) {
                alert('Error al intentar imprimir: ' + error.message);
                var btnImprimir = document.querySelector('button[onclick="imprimirFactura(false)"], button[onclick="imprimirFactura(true)"]');
                if(btnImprimir) {
                    btnImprimir.disabled = false;
                    btnImprimir.innerHTML = originalText || '<i class="lni lni-printer me-2"></i> Imprimir de Nuevo';
                }
            }
        }
    </script>
}