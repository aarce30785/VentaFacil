@model IEnumerable<VentaFacil.web.Models.Usuario>

@{
    ViewData["Title"] = "Configuración de Salario Base";
    Layout = "_LayoutPlantilla";
    var configuraciones = ViewBag.Configuraciones as Dictionary<int, VentaFacil.web.Models.ConfiguracionPlanilla>;
    var deduccionesLey  = ViewBag.DeduccionesLey  as List<VentaFacil.web.Models.Configuracion.DeduccionLey>;
}

<div class="dashboard-wrapper">
    <div class="title-wrapper pt-30 mb-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <div class="title">
                    <h2 class="fw-bold text-dark">Configuración de Planilla</h2>
                    <p class="text-muted text-sm">Tarifas por hora y tasas de deducción</p>
                </div>
            </div>
            <div class="col-md-6">
                <div class="breadcrumb-wrapper">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-controller="Planilla" asp-action="Index">Planilla</a></li>
                            <li class="breadcrumb-item active" aria-current="page">Configuración</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="lni lni-checkmark-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="lni lni-warning me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════
       SECCIÓN 1: Tasas de Deducción de Ley
    ═══════════════════════════════════════════════════════════════ *@
    <div class="row mb-4">
        <div class="col-lg-12">
            <div class="card-style mb-30 premium-card">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h6 class="mb-0"><i class="fas fa-percent text-primary me-2"></i>Tasas de Deducción de Ley</h6>
                        <small class="text-muted">Estas tasas se aplican automáticamente al generar la nómina. Si una tasa es 0%, la nómina <strong>no podrá procesarse</strong>.</small>
                    </div>
                </div>

                @if (deduccionesLey != null && deduccionesLey.Any(d => d.Activo && d.Porcentaje == 0))
                {
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3" role="alert">
                        <i class="fas fa-exclamation-triangle fa-lg"></i>
                        <div>
                            <strong>Advertencia:</strong> Existe al menos una deducción activa con porcentaje 0%. El sistema no permitirá generar la nómina hasta que se configure una tasa válida.
                        </div>
                    </div>
                }

                <div class="table-wrapper table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th><h6>Deducción</h6></th>
                                <th><h6>Tasa (%)</h6></th>
                                <th><h6>Estado</h6></th>
                                <th><h6>Acciones</h6></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (deduccionesLey != null)
                            {
                                @foreach (var ded in deduccionesLey)
                                {
                                    <tr>
                                        <td><p class="fw-semibold">@ded.Nombre</p></td>
                                        <td>
                                            @if (ded.Activo && ded.Porcentaje == 0)
                                            {
                                                <span class="badge bg-danger"><i class="fas fa-exclamation-circle me-1"></i>0 % — Sin tasa</span>
                                            }
                                            else
                                            {
                                                <p class="text-success fw-bold">@ded.Porcentaje.ToString("0.##") %</p>
                                            }
                                        </td>
                                        <td>
                                            @if (ded.Activo)
                                            {
                                                <span class="badge bg-success">Activa</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Inactiva</span>
                                            }
                                        </td>
                                        <td class="d-flex gap-2">
                                            <button type="button" class="main-btn primary-btn btn-sm rounded-md btn-hover"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editDeduccionModal"
                                                    data-id="@ded.Id"
                                                    data-nombre="@ded.Nombre"
                                                    data-porcentaje="@ded.Porcentaje.ToString("F2").Replace(",",".")"
                                                    title="Editar porcentaje">
                                                <i class="lni lni-pencil"></i> Editar tasa
                                            </button>
                                            <form asp-controller="ConfiguracionPlanilla" asp-action="ToggleDeduccion" method="post" style="display:inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="idDeduccion" value="@ded.Id" />
                                                <button type="submit" class="main-btn @(ded.Activo ? "warning-btn" : "success-btn") btn-sm rounded-md btn-hover"
                                                        onclick="return confirm('@(ded.Activo ? "¿Desactivar" : "¿Activar") la deducción \'' + '@ded.Nombre' + '\'?')">
                                                    <i class="lni @(ded.Activo ? "lni-eye-off" : "lni-eye")"></i>
                                                    @(ded.Activo ? "Desactivar" : "Activar")
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @* ═══════════════════════════════════════════════════════════════
       SECCIÓN 2: Tarifas por Hora de Empleados
    ═══════════════════════════════════════════════════════════════ *@
    <div class="row">
        <div class="col-lg-12">
            <div class="card-style mb-30 premium-card">
                <h6 class="mb-10"><i class="fas fa-users text-primary me-2"></i>Tarifa por Hora — Empleados</h6>
                <div class="table-wrapper table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th><h6>Nombre Completo</h6></th>
                                <th><h6>Correo Electrónico</h6></th>
                                <th><h6>Tarifa por Hora Actual</h6></th>
                                @if (User.IsInRole("Administrador"))
                                {
                                    <th><h6>Acciones</h6></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var usuario in Model)
                            {
                                var tieneConfig = configuraciones != null && configuraciones.ContainsKey(usuario.Id_Usr);
                                var configActual = tieneConfig ? configuraciones[usuario.Id_Usr] : null;

                                <tr>
                                    <td><p>@usuario.Nombre</p></td>
                                    <td><p>@usuario.Correo</p></td>
                                    <td>
                                        @if (tieneConfig && configActual != null)
                                        {
                                            <p class="text-success fw-bold">₡@configActual.TarifaPorHora.ToString("N2")</p>
                                        }
                                        else
                                        {
                                            <p class="text-danger">No asignada</p>
                                        }
                                    </td>
                                    @if (User.IsInRole("Administrador"))
                                    {
                                        <td>
                                            <button type="button" class="main-btn primary-btn btn-sm rounded-md btn-hover"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#editTarifaModal"
                                                    data-id="@usuario.Id_Usr"
                                                    data-nombre="@usuario.Nombre"
                                                    data-tarifa="@(tieneConfig && configActual != null ? configActual.TarifaPorHora.ToString("F2").Replace(",", ".") : "")">
                                                <i class="lni lni-pencil"></i> Modificar Tarifa
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* ─── Modal: Editar Tasa de Deducción ─────────────────────────────────────── *@
<div class="modal fade" id="editDeduccionModal" tabindex="-1" aria-labelledby="editDeduccionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header" style="background:linear-gradient(135deg,#e74c3c,#c0392b);">
                <h5 class="modal-title text-white fw-bold" id="editDeduccionModalLabel">
                    <i class="fas fa-percent me-2"></i>Editar Tasa de Deducción
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="ConfiguracionPlanilla" asp-action="GuardarDeduccion" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" name="idDeduccion" id="modalDedId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Deducción</label>
                        <input type="text" id="modalDedNombre" class="form-control bg-light" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-danger fw-semibold">Porcentaje (%)</label>
                        <div class="input-group">
                            <input type="number" step="0.01" min="0" max="100" name="porcentaje"
                                   id="modalDedPorcentaje" class="form-control" placeholder="Ej. 5.50" required />
                            <span class="input-group-text">%</span>
                        </div>
                        <small class="text-muted">Ingrese el porcentaje que se descontará del salario bruto.</small>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger"><i class="fas fa-save me-1"></i>Guardar Tasa</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ─── Modal: Editar Tarifa por Hora ───────────────────────────────────────── *@
<div class="modal fade" id="editTarifaModal" tabindex="-1" aria-labelledby="editTarifaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title text-white" id="editTarifaModalLabel">Modificar Salario Base</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="ConfiguracionPlanilla" asp-action="GuardarTarifa" method="post">
                <div class="modal-body">
                    <input type="hidden" name="idUsr" id="modalUserId" />

                    <div class="mb-3">
                        <label class="form-label" style="font-weight:600;">Empleado</label>
                        <input type="text" id="modalUserName" class="form-control bg-light" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-primary" style="font-weight:600;">Tarifa por Hora (₡)</label>
                        <div class="input-group">
                            <span class="input-group-text">₡</span>
                            <input type="number" step="0.01" min="0" name="tarifaPorHora" id="modalUserTarifa" class="form-control" placeholder="Ej. 2500" required />
                        </div>
                        <small class="text-muted">Este valor se usará para calcular el salario en la nómina.</small>
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // ── Modal Tarifa ──────────────────────────────────────────────────
            var editTarifaModal = document.getElementById('editTarifaModal');
            editTarifaModal.addEventListener('show.bs.modal', function (event) {
                var btn = event.relatedTarget;
                document.getElementById('modalUserId').value    = btn.getAttribute('data-id');
                document.getElementById('modalUserName').value  = btn.getAttribute('data-nombre');
                document.getElementById('modalUserTarifa').value = btn.getAttribute('data-tarifa');
            });

            // ── Modal Deduccion ───────────────────────────────────────────────
            var editDeduccionModal = document.getElementById('editDeduccionModal');
            editDeduccionModal.addEventListener('show.bs.modal', function (event) {
                var btn = event.relatedTarget;
                document.getElementById('modalDedId').value          = btn.getAttribute('data-id');
                document.getElementById('modalDedNombre').value       = btn.getAttribute('data-nombre');
                document.getElementById('modalDedPorcentaje').value   = btn.getAttribute('data-porcentaje');
            });
        });
    </script>
}

