@model VentaFacil.web.Models.Dto.InventarioDto

@{
    ViewData["Title"] = "Editar Insumo";
    Layout = "_LayoutPlantilla";
}

<!-- ========== table components start ========== -->
<div class="container-fluid py-4">
    <!-- Header -->
    <div class="hero-section d-flex justify-content-between align-items-center px-4" style="text-align: left; margin-top: -1.5rem; margin-bottom: 2rem;">
        <div class="position-relative z-1">
            <h1 class="hero-title fw-bold mb-2 text-white"><i class="lni lni-pencil-alt me-2"></i>Editar Insumo</h1>
            <p class="mb-0 text-white-50 fs-5">Modifica los datos del insumo seleccionado.</p>
        </div>
        <div class="position-relative z-1 d-none d-md-block">
            <div class="breadcrumb-wrapper">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#0" class="text-white-50">Dashboard</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Listar")" class="text-white-50">Inventario</a></li>
                        <li class="breadcrumb-item active text-white" aria-current="page">Editar</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    <div class="tables-wrapper">
            <div class="row">
                <div class="col-lg-12">
                    <div class="card-style mb-30">
                        <div class="card-content">
                            <form asp-action="Editar" class="row g-3">
                                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                <input type="hidden" asp-for="Id_Inventario" />

                                <div class="col-md-6">
                                    <div class="input-style-1">
                                        <label asp-for="Nombre" class="form-label">Nombre del Insumo</label>
                                        <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre del insumo" />
                                        <span asp-validation-for="Nombre" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="select-style-1">
                                        <label asp-for="UnidadMedida" class="form-label">Unidad de Medida</label>
                                        <div class="select-position">
                                            <select asp-for="UnidadMedida" class="form-control" asp-items="Html.GetEnumSelectList<VentaFacil.web.Models.Enum.UnidadMedida>()">
                                                <option value="">Seleccione una unidad</option>
                                            </select>
                                        </div>
                                        <span asp-validation-for="UnidadMedida" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <div class="input-style-1">
                                        <label asp-for="StockActual" class="form-label">Stock Actual</label>
                                        <input asp-for="StockActual" class="form-control" type="number" min="0" />
                                        <span asp-validation-for="StockActual" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="col-md-3">
                                    <div class="input-style-1">
                                        <label asp-for="StockMinimo" class="form-label">Stock Mínimo</label>
                                        <input asp-for="StockMinimo" class="form-control" type="number" min="0" />
                                        <span asp-validation-for="StockMinimo" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="col-12">
                                    <div class="button-group d-flex justify-content-between">
                                        <a href="@Url.Action("Listar")" class="main-btn light-btn btn-hover">
                                            <i class="lni lni-arrow-left me-2"></i>Volver al Inventario
                                        </a>
                                        <button type="submit" class="main-btn primary-btn btn-hover">
                                            <i class="lni lni-save me-2"></i>Guardar Cambios
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
<!-- ========== table components end ========== -->
