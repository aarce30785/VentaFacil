@{
    ViewData["Title"] = "Reportes";
    Layout = "_LayoutPlantilla";
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="hero-section d-flex justify-content-between align-items-center px-4" style="text-align: left; margin-top: -1.5rem; margin-bottom: 2rem;">
        <div class="position-relative z-1">
            <h1 class="hero-title fw-bold mb-2 text-white"><i class="lni lni-bar-chart me-2"></i>Módulo de Reportes</h1>
            <p class="mb-0 text-white-50 fs-5">Genera información histórica de movimientos y ventas.</p>
        </div>
        <div class="position-relative z-1 d-none d-md-block">
            <div class="breadcrumb-wrapper">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="#0" class="text-white-50">Dashboard</a></li>
                        <li class="breadcrumb-item active text-white" aria-current="page">Reportes</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="lni lni-warning me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <!-- Reporte Ventas Diarias -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-4">
                    <h4 class="card-title fw-bold text-dark mb-3">Ventas Diarias</h4>
                    <p class="card-text text-muted mb-4">Genera un PDF con el resumen de todas las ventas para una fecha en específico.</p>
                    
                    <form asp-action="VentasDiarias" asp-controller="Reportes" method="post" target="_blank">
                        <div class="mb-3">
                            <label for="fecha" class="form-label fw-bold">Seleccionar Fecha</label>
                            <input type="date" name="fecha" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary" style="border-radius: 8px;">
                                <i class="lni lni-download me-2"></i> Generar / Descargar PDF
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Reporte Personalizado / Avanzado -->
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-body p-4">
                    <h4 class="card-title fw-bold text-dark mb-3">Reporte Personalizado</h4>
                    <p class="card-text text-muted mb-4">Filtra transacciones por rango de fechas y/o cajero. Exportar a Excel.</p>
                    
                    <form asp-action="ReportePersonalizado" asp-controller="Reportes" method="post" target="_blank">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="fechaInicio" class="form-label fw-bold">Fecha Inicio</label>
                                <input type="date" name="fechaInicio" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </div>
                            <div class="col-md-6">
                                <label for="fechaFin" class="form-label fw-bold">Fecha Fin</label>
                                <input type="date" name="fechaFin" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="idCajero" class="form-label fw-bold">Cajero / Usuario (Opcional)</label>
                            <select name="idCajero" class="form-select" asp-items="ViewBag.Cajeros">
                                <option value="">-- Todos los cajeros --</option>
                            </select>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success" style="border-radius: 8px;">
                                <i class="lni lni-empty-file me-2"></i> Exportar a Excel
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
