@using VentaFacil.web.Models.Response.Planilla
@using VentaFacil.web.Models.Dto
@model HistorialLaboralResponse
@{
    var cultureCR = new System.Globalization.CultureInfo("es-CR");
    var numFmt = (System.Globalization.NumberFormatInfo)cultureCR.NumberFormat.Clone();
    numFmt.CurrencySymbol = "¢";
    bool esAdmin = (bool)(ViewBag.EsAdmin ?? false);
}

<style>
    .premium-card { background:#fff; border-radius:16px; box-shadow:0 10px 15px -3px rgba(0,0,0,.1),0 4px 6px -2px rgba(0,0,0,.05); border:1px solid rgba(0,0,0,.05); margin-bottom:2rem; padding:2rem 1.5rem; }
    .table-premium thead th { background:#3a5cf5; color:#fff; font-weight:600; font-size:.85rem; padding:.9rem; text-transform:uppercase; }
    .table-premium tbody tr:hover { background:#f5f7ff; }
    .badge-completada   { background:#d1fae5; color:#065f46; }
    .badge-incompleta   { background:#fee2e2; color:#991b1b; }
    .badge-pendiente    { background:#fef9c3; color:#713f12; }
</style>

<div class="title-wrapper pt-30">
    <div class="row align-items-center">
        <div class="col-md-6">
            <div class="title">
                <h2 class="fw-bold text-dark">
                    <i class="fas fa-history text-primary me-2"></i>
                    Historial Laboral — @Model.NombreUsuario
                </h2>
            </div>
        </div>
        <div class="col-md-6">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-md-end">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Inicio</a></li>
                    <li class="breadcrumb-item active">Historial Laboral</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        @if (esAdmin)
        {
            <div class="premium-card mb-3">
                <form method="get" class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Empleado</label>
                        <select name="idUsuario" asp-items="ViewBag.Usuarios" class="form-select" onchange="this.form.submit()">
                            <option value="">-- Seleccionar empleado --</option>
                        </select>
                    </div>
                    <input type="hidden" name="pagina" value="1" />
                </form>
            </div>
        }

        <div class="premium-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0">
                    Registros de los últimos 5 años
                    <span class="badge bg-primary ms-2">@Model.TotalRegistros jornadas</span>
                </h5>
                @if (!esAdmin)
                {
                    <a asp-controller="Asistencia" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="fas fa-arrow-left me-1"></i> Volver a Mis Horas
                    </a>
                }
            </div>

            <div class="table-responsive">
                <table class="table table-premium align-middle">
                    <thead>
                        <tr>
                            <th>Fecha Jornada</th>
                            <th class="text-center">Hora Entrada</th>
                            <th class="text-center">Inicio Pausa</th>
                            <th class="text-center">Fin Pausa</th>
                            <th class="text-center">Hora Salida</th>
                            <th class="text-center">Hrs Trabajadas</th>
                            <th class="text-center">Hrs Extras</th>
                            <th class="text-end">Salario Bruto</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Nómina</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Jornadas != null && Model.Jornadas.Any())
                        {
                            @foreach (var j in Model.Jornadas)
                            {
                                <tr>
                                    <td class="fw-semibold">@j.FechaInicio.ToString("ddd dd/MM/yyyy", cultureCR)</td>
                                    <td class="text-center">@j.FechaInicio.ToString("HH:mm")</td>
                                    <td class="text-center">@(j.HoraInicioPausa?.ToString("HH:mm") ?? "—")</td>
                                    <td class="text-center">@(j.HoraFinPausa?.ToString("HH:mm") ?? "—")</td>
                                    <td class="text-center">@(j.FechaFinal?.ToString("HH:mm") ?? "—")</td>
                                    <td class="text-center">@j.HorasTrabajadas.ToString("0.##") h</td>
                                    <td class="text-center">@j.HorasExtras.ToString("0.##") h</td>
                                    <td class="text-end">@j.SalarioBruto.ToString("C", numFmt)</td>
                                    <td class="text-center">
                                        @{
                                            var cls = j.EstadoRegistro switch
                                            {
                                                "Completada" => "badge-completada",
                                                "Incompleta" => "badge-incompleta",
                                                _            => "badge-pendiente"
                                            };
                                        }
                                        <span class="badge @cls rounded-pill px-3 py-2">@j.EstadoRegistro</span>
                                    </td>
                                    <td class="text-center">
                                        @if (j.Id_Nomina.HasValue)
                                        {
                                            <a href="@Url.Action("DetalleNomina","Planilla", new {idNomina=j.Id_Nomina})"
                                               class="btn btn-sm btn-outline-primary" title="Ver Nómina #@j.Id_Nomina">
                                                <i class="fas fa-file-invoice-dollar"></i> #@j.Id_Nomina
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">Sin nómina</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="10" class="text-center py-5 text-muted">
                                    <i class="fas fa-folder-open fs-2 mb-2 d-block"></i>
                                    No se encontraron jornadas en los últimos 5 años.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Paginación *@
            @if (Model.TotalPaginas > 1)
            {
                <nav class="mt-3">
                    <ul class="pagination justify-content-end">
                        <li class="page-item @(Model.PaginaActual == 1 ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("HistorialLaboral","Planilla", new {idUsuario=Model.Id_Usr, pagina=Model.PaginaActual-1})">&laquo;</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPaginas; i++)
                        {
                            <li class="page-item @(i == Model.PaginaActual ? "active" : "")">
                                <a class="page-link" href="@Url.Action("HistorialLaboral","Planilla", new {idUsuario=Model.Id_Usr, pagina=i})">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.PaginaActual == Model.TotalPaginas ? "disabled" : "")">
                            <a class="page-link" href="@Url.Action("HistorialLaboral","Planilla", new {idUsuario=Model.Id_Usr, pagina=Model.PaginaActual+1})">&raquo;</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
