@model VentaFacil.web.Models.Dto.InventarioMovimientoDto

<div class="modal fade" id="corregirMovimientoModal" tabindex="-1" aria-labelledby="corregirMovimientoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow-lg">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold" id="corregirMovimientoModalLabel">
                    <i class="lni lni-pencil text-primary me-2"></i> Corregir Movimiento de Inventario
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body py-4">
                <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                    <i class="lni lni-warning fs-4 me-3"></i>
                    <div>
                        <strong>Advertencia:</strong> Esta acción modificará el stock del inventario y quedará registrada en la auditoría.
                    </div>
                </div>

                <form id="corregirMovimientoForm" method="post" action="@Url.Action("CorregirMovimiento", "Inventario")">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id_Movimiento" id="corregir_Id_Movimiento" value="@Model.Id_Movimiento" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group mb-0">
                                <label class="form-label text-sm text-muted fw-bold">ID Movimiento</label>
                                <input type="text" value="@Model.Id_Movimiento" class="form-control rounded-3 bg-light border-0 px-3" disabled />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-0">
                                <label class="form-label text-sm text-muted fw-bold">ID Inventario</label>
                                <input type="text" value="@Model.Id_Inventario" class="form-control rounded-3 bg-light border-0 px-3" disabled />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-0">
                                <label class="form-label text-sm text-muted fw-bold">Cantidad Actual</label>
                                <input type="text" value="@Model.Cantidad" class="form-control rounded-3 bg-light border-0 px-3" disabled />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-0">
                                <label class="form-label text-sm text-muted fw-bold">Tipo Actual</label>
                                <input type="text" value="@Model.Tipo_Movimiento" class="form-control rounded-3 bg-light border-0 px-3" disabled />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-0">
                                <label for="corregir_Cantidad" class="form-label text-sm text-muted fw-bold">Nueva Cantidad <span class="text-danger">*</span></label>
                                <input type="number" name="Cantidad" id="corregir_Cantidad" class="form-control rounded-3 border px-3" value="@Model.Cantidad" min="1" required />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-0">
                                <label for="corregir_Tipo_Movimiento" class="form-label text-sm text-muted fw-bold">Nuevo Tipo <span class="text-danger">*</span></label>
                                <select name="Tipo_Movimiento" id="corregir_Tipo_Movimiento" class="form-control rounded-3 border px-3" required>
                                    @{
                                        var tiposEstandar = new[] { "Entrada", "Salida" };
                                        var tipoActual = Model.Tipo_Movimiento;
                                        var esTipoEstandar = tiposEstandar.Contains(tipoActual);
                                    }

                                    @if (!esTipoEstandar)
                                    {
                                        <option value="@tipoActual" selected>@tipoActual</option>
                                    }

                                    @foreach (var tipo in tiposEstandar)
                                    {
                                        if (tipo == tipoActual)
                                        {
                                            <option value="@tipo" selected>@tipo</option>
                                        }
                                        else
                                        {
                                            <option value="@tipo">@tipo</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-group mb-0">
                                <label for="corregir_Motivo" class="form-label text-sm text-muted fw-bold">Motivo de la Corrección <span class="text-danger">*</span></label>
                                <textarea name="Motivo" id="corregir_Motivo" class="form-control rounded-3 border px-3" rows="3" placeholder="Explique el motivo de la corrección..." required></textarea>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            
            <div class="modal-footer border-top-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="btnGuardarCorreccion">
                    <i class="lni lni-checkmark me-1"></i> Guardar Corrección
                </button>
            </div>
        </div>
    </div>
</div>
