@model IEnumerable<VentaFacil.web.Models.Dto.CajaDto>

@{
    ViewData["Title"] = "Caja";
    Layout = "_LayoutPlantilla";
    var cajaAbierta = Model.FirstOrDefault(c => c.Estado == "Abierta" && c.Fecha_Apertura.Date == DateTime.Now.Date);
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        --success-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
        --warning-gradient: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
        --danger-gradient: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        --info-gradient: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        --mustard: #f59e0b;
        --mustard-hover: #d97706;
        --card-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
        --hover-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    }
    .premium-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 2rem;
        padding: 2rem 1.5rem 1.5rem 1.5rem;
    }
    .premium-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--hover-shadow);
    }
    .table-container {
        background: #fff;
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        padding: 1.5rem;
        margin-bottom: 2rem;
    }
    .premium-table thead th {
        background-color: #f8fafc;
        color: #222 !important;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        border-bottom: 2px solid #e2e8f0;
        padding: 1rem;
    }
    .premium-table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        color: #334155;
    }
    .premium-table tbody tr:last-child td {
        border-bottom: none;
    }
    .premium-table tbody tr:hover {
        background-color: #f8fafc;
    }
    .caja-actions button {
        margin-right: 0.5rem;
        margin-bottom: 0.25rem;
    }
    .btn-mustard {
        background-color: var(--mustard) !important;
        color: #fff !important;
        border: none;
        border-radius: 30px !important;
        font-weight: 600;
        padding: 0.5rem 1.2rem;
    }
    .btn-mustard:hover, .btn-mustard:focus {
        background-color: var(--mustard-hover) !important;
        color: #fff !important;
    }
    .btn-premium {
        border-radius: 30px !important;
        font-weight: 600;
        padding: 0.5rem 1.5rem;
    }
</style>

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="hero-section d-flex justify-content-between align-items-center px-4" style="text-align: left; margin-top: -1.5rem; margin-bottom: 2rem;">
        <div class="position-relative z-1">
            <h1 class="hero-title fw-bold mb-2 text-white"><i class="lni lni-wallet me-2"></i>Administrar Caja</h1>
            <p class="mb-0 text-white-50 fs-5">Control de apertura, cierre y movimientos de caja.</p>
        </div>
        <div class="position-relative z-1 d-none d-md-block">
            <div class="d-flex gap-2">
                @if (cajaAbierta == null)
                {
                    <button type="button" class="btn fw-bold rounded-pill px-4 py-2 shadow-sm" style="background-color: #FFF8DC; color: #1e293b; border: 2px solid #FFD700;" data-bs-toggle="modal" data-bs-target="#abrirCajaModal">
                        <i class="lni lni-plus me-2"></i> Abrir caja
                    </button>
                }
                else
                {
                    <a href="@Url.Action("GenerarArqueo", "Caja", new { idCaja = cajaAbierta.Id_Caja })" class="btn fw-bold rounded-pill px-4 py-2 shadow-sm" style="background-color: #FFF8DC; color: #1e293b; border: 2px solid #FFD700;" target="_blank">
                        <i class="lni lni-printer me-2"></i> Arqueo / Corte
                    </a>
                    <button type="button" class="btn fw-bold rounded-pill px-4 py-2 shadow-sm" style="background-color: #FFF8DC; color: #dc2626; border: 2px solid #FFD700;" data-bs-toggle="modal" data-bs-target="#cerrarCajaModal">
                        <i class="lni lni-lock me-2"></i> Cerrar Caja
                    </button>
                    <button type="button" class="btn fw-bold rounded-pill px-4 py-2 shadow-sm" style="background-color: #FFF8DC; color: #d97706; border: 2px solid #FFD700;" data-bs-toggle="modal" data-bs-target="#retiroCajaModal">
                        <i class="lni lni-minus me-2"></i> Retiro
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="premium-card">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="lni lni-checkmark-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="lni lni-warning me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="table-container">
        <table class="table premium-table">
            <thead>
                <tr>
                    
                    <th>@Html.DisplayNameFor(model => model.Fecha_Apertura)</th>
                    <th>@Html.DisplayNameFor(model => model.Fecha_Cierre)</th>
                    <th>@Html.DisplayNameFor(model => model.Monto_Inicial)</th>
                    <th>@Html.DisplayNameFor(model => model.Monto)</th>
                    <th>@Html.DisplayNameFor(model => model.Monto_Inicial_USD)</th>
                    <th>@Html.DisplayNameFor(model => model.Monto_USD)</th>
                    <th>@Html.DisplayNameFor(model => model.Estado)</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model) {
                <tr>
                    
                    <td>@Html.DisplayFor(modelItem => item.Fecha_Apertura)</td>
                    <td>@Html.DisplayFor(modelItem => item.Fecha_Cierre)</td>
                    <td class="text-success fw-bold">@((item.Monto_Inicial).ToString("C"))</td>
                    <td class="text-success fw-bold">@(((decimal)(item.Monto ?? 0)).ToString("C"))</td>
                    <td class="text-info fw-bold">$@((item.Monto_Inicial_USD).ToString("N2"))</td>
                    <td class="text-info fw-bold">$@(((decimal)(item.Monto_USD ?? 0)).ToString("N2"))</td>
                    <td>@Html.DisplayFor(modelItem => item.Estado)</td>
                    <td class="caja-actions">
                        <button type="button" class="btn btn-mustard btn-sm" data-bs-toggle="modal" data-bs-target="#retirosModal" data-caja-id="@item.Id_Caja">
                            <i class="fas fa-eye"></i> Ver Retiros
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    </div>
</div>

<!-- Modal Abrir Caja -->
<div class="modal fade" id="abrirCajaModal" tabindex="-1" aria-labelledby="abrirCajaModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="abrirCajaModalLabel">Abrir Caja</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <form asp-action="Abrir" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label for="montoInicial" class="control-label fw-bold">Fondo Inicial Colones (¢)</label>
                <input type="number" step="0.01" min="0" name="montoInicial" class="form-control" required placeholder="0.00" />
            </div>
            <div class="form-group mb-3">
                <label for="montoInicialUSD" class="control-label fw-bold text-info">Fondo Inicial Dólares ($)</label>
                <input type="number" step="0.01" min="0" name="montoInicialUSD" value="0.00" class="form-control" required placeholder="0.00" />
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Abrir Caja</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Modal Cerrar Caja -->
<div class="modal fade" id="cerrarCajaModal" tabindex="-1" aria-labelledby="cerrarCajaModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="cerrarCajaModalLabel">Cierre de Caja</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-info py-2 mb-3 d-flex justify-content-between">
            <div>
                <strong>Sistema (CRC): </strong>
                <span class="fs-5 text-success fw-bold">@(((decimal)(cajaAbierta?.Monto ?? 0)).ToString("C"))</span>
            </div>
            <div>
                <strong>Sistema (USD): </strong>
                <span class="fs-5 text-info fw-bold">$@(((decimal)(cajaAbierta?.Monto_USD ?? 0)).ToString("N2"))</span>
            </div>
        </div>
        <form asp-action="CerrarConfirmado" method="post" id="formCerrarCaja">
            <input type="hidden" name="id" value="@cajaAbierta?.Id_Caja" />
            <input type="hidden" id="montoEsperadoCierre" value="@(cajaAbierta?.Monto ?? 0)" />
            <input type="hidden" id="montoEsperadoCierreUSD" value="@(cajaAbierta?.Monto_USD ?? 0)" />
            
            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label for="montoFisico" class="control-label fw-bold">Físico Colones (¢)</label>
                    <input type="number" step="0.01" min="0" id="montoFisico" name="montoFisico" class="form-control" required placeholder="Dinero real ¢..." />
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label for="montoFisicoUSD" class="control-label fw-bold text-info">Físico Dólares ($)</label>
                    <input type="number" step="0.01" min="0" id="montoFisicoUSD" name="montoFisicoUSD" class="form-control" required placeholder="Dinero real $..." />
                </div>
            </div>

            <div id="discrepanciaContainer" style="display:none;" class="p-3 mb-3 rounded">
                <p class="mb-1 fw-bold" id="discrepanciaTexto"></p>
                <p class="mb-1 fw-bold" id="discrepanciaTextoUSD"></p>
                <div class="form-group mt-2">
                    <label for="justificacion" class="control-label text-danger">Justificación de la Diferencia</label>
                    <textarea id="justificacion" name="justificacion" class="form-control" rows="2" placeholder="Explique la causa del sobrante o faltante..."></textarea>
                </div>
            </div>

            <div class="modal-footer">
                <button type="submit" class="btn btn-danger">Confirmar cierre</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Modal Retiro de Caja -->
<div class="modal fade" id="retiroCajaModal" tabindex="-1" aria-labelledby="retiroCajaModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="retiroCajaModalLabel">Retiro de Caja</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <form asp-action="Retiro" method="post">
            <input type="hidden" name="id" value="@cajaAbierta?.Id_Caja" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label for="monto" class="control-label fw-bold">Monto a retirar (¢)</label>
                <input type="number" step="0.01" min="0.01" name="monto" class="form-control" required placeholder="0.00" />
            </div>
            <div class="form-group mb-3">
                <label for="motivo" class="control-label fw-bold">Motivo o Justificación</label>
                <input type="text" name="motivo" class="form-control" required placeholder="Ej: Pago a proveedores, compra de insumos..." />
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-warning">Retirar</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Modal Ver Retiros -->
<div class="modal fade" id="retirosModal" tabindex="-1" aria-labelledby="retirosModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="retirosModalLabel">Retiros de Caja</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body" id="retirosModalBody">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $('#retirosModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var cajaId = button.data('caja-id');
            var modal = $(this);
            modal.find('.modal-body').load('/Caja/Retiros/' + cajaId);
        });

        function calcularDiscrepancias() {
            var esperadoCRC = parseFloat($('#montoEsperadoCierre').val()) || 0;
            var fisicoCRC = parseFloat($('#montoFisico').val()) || 0;
            var difCRC = fisicoCRC - esperadoCRC;

            var esperadoUSD = parseFloat($('#montoEsperadoCierreUSD').val()) || 0;
            var fisicoUSD = parseFloat($('#montoFisicoUSD').val()) || 0;
            var difUSD = fisicoUSD - esperadoUSD;
            
            var container = $('#discrepanciaContainer');
            var spanTextCRC = $('#discrepanciaTexto');
            var spanTextUSD = $('#discrepanciaTextoUSD');
            var txtJustif = $('#justificacion');

            var hasDiffCRC = Math.abs(difCRC) > 0.01;
            var hasDiffUSD = Math.abs(difUSD) > 0.01;

            if (hasDiffCRC || hasDiffUSD) {
                container.show();
                txtJustif.prop('required', true);
                
                // Color de fondo general
                if (difCRC >= 0 && difUSD >= 0) {
                    container.css('background-color', '#d1e7dd');
                } else {
                    container.css('background-color', '#f8d7da');
                }

                if(hasDiffCRC) {
                    if (difCRC > 0) {
                        spanTextCRC.html('CRC Sobran: <span class="text-success">' + difCRC.toLocaleString('es-CR', {style:'currency', currency:'CRC'}) + '</span>').show();
                    } else {
                        spanTextCRC.html('CRC Faltan: <span class="text-danger">' + Math.abs(difCRC).toLocaleString('es-CR', {style:'currency', currency:'CRC'}) + '</span>').show();
                    }
                } else {
                    spanTextCRC.hide();
                }

                if(hasDiffUSD) {
                    if (difUSD > 0) {
                        spanTextUSD.html('USD Sobran: <span class="text-success">$' + difUSD.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '</span>').show();
                    } else {
                        spanTextUSD.html('USD Faltan: <span class="text-danger">$' + Math.abs(difUSD).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + '</span>').show();
                    }
                } else {
                    spanTextUSD.hide();
                }

            } else {
                container.hide();
                txtJustif.prop('required', false);
                txtJustif.val('');
            }
        }

        $('#montoFisico, #montoFisicoUSD').on('input', calcularDiscrepancias);
    </script>
}